---
/**
 * FilterColorSwatches Component
 *
 * Visual color picker with swatches for filtering materials by color.
 */
import { useI18n } from '../../i18n/utils';
import materialsData from '../../data/materials.json';

const { t } = useI18n(Astro.url);

const colors = materialsData.filterMetadata.colors;
---

<div class="filter-color-swatches" data-filter-group="colors">
  <span class="block text-sm font-medium text-gray-700 mb-3">
    {t.materials.filters.color}
  </span>

  <div class="flex flex-wrap gap-2">
    {colors.map((color) => (
      <button
        type="button"
        class="color-swatch relative w-8 h-8 rounded-full border-2 border-gray-200 hover:border-gray-400 transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary"
        style={`background-color: ${color.hex};`}
        data-filter-color={color.id}
        title={t.materials.colors[color.id as keyof typeof t.materials.colors]}
        aria-label={t.materials.colors[color.id as keyof typeof t.materials.colors]}
      >
        <svg
          class="absolute inset-0 m-auto w-4 h-4 text-white opacity-0 transition-opacity check-icon"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
        </svg>
      </button>
    ))}
  </div>
</div>

<style>
  .color-swatch.active {
    border-color: #1f2937;
    box-shadow: 0 0 0 2px white, 0 0 0 4px #1f2937;
  }

  .color-swatch.active .check-icon {
    opacity: 1;
  }

  /* For light colors, use dark checkmark */
  .color-swatch[data-filter-color="white"] .check-icon,
  .color-swatch[data-filter-color="silver"] .check-icon {
    color: #374151;
  }
</style>
